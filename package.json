{
  "name": "elementarywatson",
  "displayName": "ElementaryWatson",
  "icon": "icon.png",
  "publisher": "romerramos",
  "keywords": [
    "i18n",
    "translation",
    "internationalization",
    "paraglide",
    "paraglidejs",
    "svelte",
    "sveltekit",
    "sherlock",
    "inlang",
    "elementary",
    "watson",
    "elementarywatson"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/romerramos/elementary-watson.git"
  },
  "author": {
    "name": "Romer"
  },
  "description": "VS Code extension that displays inline translation values for Paraglide JS i18n method calls in Svelte/SvelteKit applications",
  "version": "0.6.0",
  "engines": {
    "vscode": "^1.99.3"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:svelte"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "ElementaryWatson",
      "properties": {
        "elementaryWatson.defaultLocale": {
          "type": "string",
          "default": "en",
          "description": "Default locale for displaying translation labels. If not set, will use the baseLocale from project.inlang settings or fallback to 'en'.",
          "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
          "patternErrorMessage": "Locale must be in format 'en' or 'en-US'"
        },
        "elementaryWatson.realtimeUpdates": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time updates of translation labels while typing. When disabled, labels only update on save."
        },
        "elementaryWatson.updateDelay": {
          "type": "number",
          "default": 300,
          "minimum": 100,
          "maximum": 2000,
          "description": "Delay in milliseconds before updating translation labels after typing stops (100-2000ms)."
        },
        "elementaryWatson.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Enable the CodeLens actions above translation calls. Inline translation labels and decorations remain visible when this is disabled."
        }
      }
    },
    "views": {
      "elementaryWatson": [
        {
          "id": "elementaryWatsonSidebar",
          "name": "Translation Keys",
          "when": "elementaryWatson.showSidebar"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "elementaryWatson",
          "title": "ElementaryWatson",
          "icon": "$(globe)"
        }
      ]
    },
    "commands": [
      {
        "command": "elementaryWatson.changeLocale",
        "title": "Change Label Locales",
        "category": "ElementaryWatson"
      },
      {
        "command": "elementaryWatson.inspectTranslation",
        "title": "Inspect Translation",
        "category": "ElementaryWatson"
      },
      {
        "command": "elementaryWatson.extractText",
        "title": "Extract Text to Locale",
        "category": "ElementaryWatson"
      },
      {
        "command": "elementaryWatson.openTranslationFile",
        "title": "Open Translation File",
        "icon": "$(target)"
      },
      {
        "command": "elementaryWatson.renameKey",
        "title": "Rename Translation Key",
        "category": "ElementaryWatson"
      }
    ],
    "keybindings": [
      {
        "command": "elementaryWatson.renameKey",
        "key": "f2",
        "when": "editorTextFocus && elementaryWatson.isCursorOnI18nCall"
      }
    ],
    "editor/context": [
      {
        "command": "elementaryWatson.inspectTranslation",
        "when": "editorTextFocus && elementaryWatson.isCursorOnI18nCall",
        "group": "navigation"
      },
      {
        "command": "elementaryWatson.renameKey",
        "when": "editorTextFocus && elementaryWatson.isCursorOnI18nCall",
        "group": "navigation"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "lint-tsc": "tsc -noEmit -skipLibCheck",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.99.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.25.1"
  },
  "dependencies": {
    "human-id": "^4.1.1"
  }
}
